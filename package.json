    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "export": "expo export --platform all --output-dir dist",
    "build:web": "expo export --platform web --output-dir dist",
    "build:preview": "eas build --profile preview --platform all",
    "build:production": "eas build --profile production --platform all",
